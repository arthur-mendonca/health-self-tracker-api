{
  "info": {
    "name": "Health Self Tracker API",
    "description": "Colecao de requests HTTP do backend. Atualizar sempre que novas rotas forem adicionadas.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"local-password\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        }
      ]
    },
    {
      "name": "Tags",
      "item": [
        {
          "name": "List tags",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": "{{baseUrl}}/tags"
          }
        },
        {
          "name": "Create tag",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Headache\",\n  \"category\": \"SYMPTOM\"\n}"
            },
            "url": "{{baseUrl}}/tags"
          }
        }
      ]
    },
    {
      "name": "Substances",
      "item": [
        {
          "name": "List substances",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": "{{baseUrl}}/substances"
          }
        },
        {
          "name": "Create substance",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Magnesium\",\n  \"type\": \"SUPPLEMENT\",\n  \"defaultDose\": \"200mg\"\n}"
            },
            "url": "{{baseUrl}}/substances"
          }
        }
      ]
    },
    {
      "name": "Activities",
      "item": [
        {
          "name": "List activities",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": "{{baseUrl}}/activities"
          }
        },
        {
          "name": "Create activity",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Walk\"\n}"
            },
            "url": "{{baseUrl}}/activities"
          }
        }
      ]
    },
    {
      "name": "Records",
      "item": [
        {
          "name": "Upsert daily record",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"date\": \"2026-04-15\",\n  \"metrics\": {\n    \"energy\": 4,\n    \"sleepQuality\": 3\n  },\n  \"structuredNotes\": {\n    \"mood\": \"stable\",\n    \"focus\": \"deep work\"\n  },\n  \"tags\": [\n    {\n      \"name\": \"Headache\",\n      \"category\": \"SYMPTOM\"\n    }\n  ],\n  \"substances\": [\n    {\n      \"name\": \"Magnesium\",\n      \"type\": \"SUPPLEMENT\",\n      \"defaultDose\": \"200mg\",\n      \"exactDose\": \"200mg\",\n      \"effectDropTime\": \"NONE\",\n      \"experiencedCrash\": false\n    }\n  ],\n  \"activities\": [\n    {\n      \"name\": \"Walk\",\n      \"notes\": \"30 minutes\"\n    }\n  ]\n}"
            },
            "url": "{{baseUrl}}/records"
          }
        },
        {
          "name": "Get today record",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": "{{baseUrl}}/records/today"
          }
        }
      ]
    },
    {
      "name": "Export",
      "item": [
        {
          "name": "Dump",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": "{{baseUrl}}/export/dump"
          }
        },
        {
          "name": "Dump CSV",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": "{{baseUrl}}/export/dump.csv"
          }
        }
      ]
    }
  ]
}
